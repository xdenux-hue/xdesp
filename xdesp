local function createButton(text, callback, isToggle, initialState)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.45, -5, 0, hubStyle.buttonHeight)
    btn.Position = UDim2.new(0, 5, 0, yPos)
    btn.BackgroundColor3 = (isToggle and initialState) and hubStyle.buttonOnColor or hubStyle.buttonOffColor
    btn.BackgroundTransparency = hubStyle.buttonTransparency
    btn.Text = text
    btn.TextColor3 = hubStyle.textColor
    btn.TextScaled = true
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = mainFrame
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 8)
    btnCorner.Parent = btn
    
    local state = initialState
    btn.MouseButton1Click:Connect(function()
        if isToggle then
            state = not state
            btn.BackgroundColor3 = state and hubStyle.buttonOnColor or hubStyle.buttonOffColor
        end
        callback(state)
    end)
    
    yPos = yPos + hubStyle.buttonHeight + 5
    return btn
end

