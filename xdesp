-- Обработка нажатия клавиши
userInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == settings.aimbotKey and settings.aimbotEnabled then
        local target = getClosestPlayerToMouse()
        if target then
            aimAt(target)
        end
    end
end)

-- ============================================
-- ДОПОЛНИТЕЛЬНО: Авто-наведение (удерживать кнопку)
-- ============================================
local aimbotActive = false

userInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == settings.aimbotKey then
        aimbotActive = true
        while aimbotActive and settings.aimbotEnabled do
            local target = getClosestPlayerToMouse()
            if target then
                aimAt(target)
            end
            runService.RenderStepped:Wait()
        end
    end
end)

userInputService.InputEnded:Connect(function(input)
    if input.KeyCode == settings.aimbotKey then
        aimbotActive = false
    end
end)

