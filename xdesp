local espObjects = {}

local function clearEsp()
    for _, v in pairs(espObjects) do
        if v and v.Parent then v:Destroy() end
    end
    espObjects = {}
end

local function drawBox(pos, size, color)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, size.X, 0, size.Y)
    frame.Position = UDim2.new(0, pos.X - size.X / 2, 0, pos.Y - size.Y / 2)
    frame.BackgroundTransparency = 0.3
    frame.BackgroundColor3 = color
    frame.BorderSizePixel = 0
    frame.Parent = screenGui
    table.insert(espObjects, frame)
    return frame
end

local function drawText(pos, text, color)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 200, 0, 16)
    label.Position = UDim2.new(0, pos.X - 100, 0, pos.Y)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = color
    label.TextScaled = true
    label.Font = Enum.Font.SourceSans
    label.Parent = screenGui
    table.insert(espObjects, label)
    return label
end

local function worldToScreen(point)
    local vec, onScreen = camera:WorldToScreenPoint(point)
    if not onScreen then return nil end
    return Vector2.new(vec.X, vec.Y)
end

