-- ФУНКЦИЯ ПОИСКА ИГРОКОВ
-- ============================================
local function isPlayerValid(target)
    if not target or not target.Character then return false end
    if target == player then return false end
    local humanoid = target.Character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    return true
end

local function getPlayers()
    local list = {}
    for _, v in ipairs(players:GetPlayers()) do
        if isPlayerValid(v) then
            table.insert(list, v)
        end
    end
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and not players:FindFirstChild(v.Name) then
            if v.Humanoid.Health > 0 then
                table.insert(list, v)
            end
        end
    end
    return list
end

-- ============================================
-- НЕВИДИМКА
-- ============================================
local function setInvisible(state)
    settings.invisible = state
    local character = player.Character
    if not character then return end
    
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = state and 1 or 0
            if state then
                part.CanCollide = false
            else
                part.CanCollide = true
            end
        elseif part:IsA("Decal") or part:IsA("Texture") then
            part.Transparency = state and 1 or 0
        end
    end
    
    for _, child in ipairs(character:GetChildren()) do
        if child:IsA("Shirt") or child:IsA("Pants") or child:IsA("Accessory") or child:IsA("Clothing") or child:IsA("Hat") then
            child.Transparency = state and 1 or 0
        end
    end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if humanoid then
        for _, bodyPart in ipairs(humanoid:GetDescendants()) do
            if bodyPart:IsA("BasePart") then
                bodyPart.Transparency = state and 1 or 0
            end
        end
    end
end

