local espObjects = {}

local function clearEsp()
    for _, v in pairs(espObjects) do
        if v and v.Parent then v:Destroy() end
    end
    espObjects = {}
end

local function drawBox(pos, size, color)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, size.X, 0, size.Y)
    frame.Position = UDim2.new(0, pos.X - size.X / 2, 0, pos.Y - size.Y / 2)
    frame.BackgroundTransparency = 0.3
    frame.BackgroundColor3 = color
    frame.BorderSizePixel = 0
    frame.Parent = screenGui
    table.insert(espObjects, frame)
    return frame
end

local function drawText(pos, text, color)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 200, 0, 16)
    label.Position = UDim2.new(0, pos.X - 100, 0, pos.Y)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = color
    label.TextScaled = true
    label.Font = Enum.Font.SourceSans
    label.Parent = screenGui
    table.insert(espObjects, label)
    return label
end

local function worldToScreen(point)
    local vec, onScreen = camera:WorldToScreenPoint(point)
    if not onScreen then return nil end
    return Vector2.new(vec.X, vec.Y), onScreen
end

runService.RenderStepped:Connect(function()
    if not settings.espEnabled then clearEsp(); return end
    clearEsp()
    
    for _, target in ipairs(getPlayers()) do
        local char = target.Character
        if char then
            local root = char:FindFirstChild("HumanoidRootPart")
            local head = char:FindFirstChild("Head")
            local humanoid = char:FindFirstChild("Humanoid")
            if root and head and humanoid and humanoid.Health > 0 then
                local headPos, onScreen = worldToScreen(head.Position)
                local rootPos, _ = worldToScreen(root.Position - Vector3.new(0, 2, 0))
                if onScreen then
                    local height = (rootPos.Y - headPos.Y)
                    local width = height / 2
                    local color = settings.espColor
                    
                    if target:IsA("Player") and target.Team and target.Team == player.Team then
                        color = settings.teamColor
                    end
                    
                    if settings.espBox then
                        drawBox(Vector2.new(headPos.X, (headPos.Y + rootPos.Y) / 2), Vector2.new(width, height), color)
                    end
                    if settings.espName then
                        drawText(Vector2.new(headPos.X, headPos.Y - 25), target.Name, color)
                    end
                    if settings.espHealth then
                        local hp = math.round(humanoid.Health / humanoid.MaxHealth * 100)
                        drawText(Vector2.new(headPos.X, headPos.Y + 5), hp .. "%", Color3.fromRGB(255, 0, 0))
                    end
                    if settings.espDistance then
                        local dist = math.round((camera.CFrame.Position - root.Position).Magnitude)
                        drawText(Vector2.new(headPos.X, headPos.Y + 25), dist .. "m", Color3.fromRGB(255, 255, 255))
                    end
                end
            end
        end
    end
end)

-- ============================================
-- AIMBOT (ИСПРАВЛЕН)
-- ============================================
local function getClosestPlayerToMouse()
    local mousePos = userInputService:GetMouseLocation()
    local closest, closestDist = nil, settings.fovRadius
    for _, target in ipairs(getPlayers()) do
        local char = target.Character
        if char then
            local part = char:FindFirstChild(settings.aimPart)
            if part then
                local pos, onScreen = worldToScreen(part.Position)
                if onScreen then
                    local dist = (mousePos - pos).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        closest = target
                    end
                end
            end
        end
    end
    return closest
end

local function aimAt(target)
    if not target or not target.Character then return end
    local part = target.Character:FindFirstChild(settings.aimPart)
    if not part then return end
    local targetPos = part.Position
    local newCFrame = CFrame.lookAt(camera.CFrame.Position, targetPos)
    camera.CFrame = camera.CFrame:Lerp(newCFrame, settings.smoothness)
end

local aimbotActive = false
userInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == settings.aimbotKey and settings.aimbotEnabled then
        aimbotActive = true
        while aimbotActive and settings.aimbotEnabled do
            local target = getClosestPlayerToMouse()
            if target then aimAt(target) end
            runService.RenderStepped:Wait()
        end
    end
end)

userInputService.InputEnded:Connect(function(input)
    if input.KeyCode == settings.aimbotKey then aimbotActive = false end
end)

