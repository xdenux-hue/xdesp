-- КАСТОМНЫЙ ПРИЦЕЛ
-- ============================================
local crosshairGroup = Instance.new("Frame")
crosshairGroup.Size = UDim2.new(0, 0, 0, 0)
crosshairGroup.Position = UDim2.new(0.5, 0, 0.5, 0)
crosshairGroup.BackgroundTransparency = 1
crosshairGroup.Parent = screenGui

local crosshairParts = {}

local function createCrosshairPart(size, position, color, transparency)
    local part = Instance.new("Frame")
    part.Size = UDim2.new(0, size.X, 0, size.Y)
    part.Position = UDim2.new(0, position.X, 0, position.Y)
    part.BackgroundColor3 = color
    part.BackgroundTransparency = transparency or 0
    part.BorderSizePixel = 0
    part.Parent = crosshairGroup
    return part
end

local function updateCrosshair()
    for _, part in ipairs(crosshairParts) do
        part:Destroy()
    end
    crosshairParts = {}
    
    if not settings.crosshairEnabled then return end
    
    local size = settings.crosshairSize
    local color = settings.crosshairColor
    local type = settings.crosshairType
    
    if type == "plus" then
        local hLine = createCrosshairPart(Vector2.new(size * 2, 2), Vector2.new(-size, -1), color)
        table.insert(crosshairParts, hLine)
        local vLine = createCrosshairPart(Vector2.new(2, size * 2), Vector2.new(-1, -size), color)
        table.insert(crosshairParts, vLine)
        local dot = createCrosshairPart(Vector2.new(4, 4), Vector2.new(-2, -2), color)
        table.insert(crosshairParts, dot)
    elseif type == "dot" then
        local dot = createCrosshairPart(Vector2.new(size, size), Vector2.new(-size/2, -size/2), color)
        table.insert(crosshairParts, dot)
    elseif type == "circle" then
        for i = 0, 3 do
            local angle = math.rad(i * 90)
            local x = math.cos(angle) * size
            local y = math.sin(angle) * size
            local frame = createCrosshairPart(Vector2.new(4, 4), Vector2.new(x - 2, y - 2), color)
            table.insert(crosshairParts, frame)
        end
    end
end

