-- ============================================
-- ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
-- ============================================
local function isPlayerValid(target)
    if not target or not target.Character or not target.Character:FindFirstChild("Humanoid") then
        return false
    end
    if target == player then
        return false
    end
    if target.Character.Humanoid.Health <= 0 then
        return false
    end
    return true
end

local function getPlayers()
    local list = {}
    for _, v in ipairs(players:GetPlayers()) do
        if isPlayerValid(v) then
            table.insert(list, v)
        end
    end
    return list
end

local function worldToScreen(point)
    local vec, onScreen = camera:WorldToScreenPoint(point)
    return Vector2.new(vec.X, vec.Y), onScreen
end

-- ============================================
-- ESP ОТРИСОВКА
-- ============================================
local espObjects = {}

local function createEspObject()
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 1, 0, 1)
    frame.BackgroundTransparency = 1
    frame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    frame.BorderSizePixel = 0
    frame.Parent = screenGui
    return frame
end

local function drawBox(target, position, size, color)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, size.X, 0, size.Y)
    frame.Position = UDim2.new(0, position.X - size.X / 2, 0, position.Y - size.Y / 2)
    frame.BackgroundTransparency = 0.3
    frame.BackgroundColor3 = color
    frame.BorderSizePixel = 0
    frame.Parent = target
    return frame
end

local function drawText(target, position, text, color)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 200, 0, 16)
    label.Position = UDim2.new(0, position.X - 100, 0, position.Y)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = color
    label.TextScaled = true
    label.Font = Enum.Font.SourceSans
    label.Parent = target
    return label
end

-- Очистка ESP объектов
local function clearEsp()
    for _, v in pairs(espObjects) do
        if v and v.Parent then
            v:Destroy()
        end
    end
    espObjects = {}
end

-- ============================================
-- ОСНОВНОЙ ЦИКЛ ESP
-- ============================================
runService.RenderStepped:Connect(function()
    if not settings.espEnabled then
        clearEsp()
        return
    end
    
    clearEsp()
    
    for _, target in ipairs(getPlayers()) do
        local character = target.Character
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid and humanoid.Health > 0 then
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            if rootPart then
                local head = character:FindFirstChild("Head")
                if head then
                    local headPos, onScreen = worldToScreen(head.Position)
                    local rootPos, _ = worldToScreen(rootPart.Position - Vector3.new(0, 2, 0))
                    
                    if onScreen then
                        local height = (rootPos.Y - headPos.Y)
                        local width = height / 2
                        local color = settings.espColor
                        
                        -- Меняем цвет для союзников
                        if target.Team and target.Team == player.Team then
                            color = settings.teamColor
                        end
                        
                        -- Рисуем ESP
                        if settings.espBox then
                            local box = drawBox(screenGui, Vector2.new(headPos.X, (headPos.Y + rootPos.Y) / 2), 
                                Vector2.new(width, height), color)
                            table.insert(espObjects, box)
                        end
                        
                        if settings.espName then
                            local nameLabel = drawText(screenGui, Vector2.new(headPos.X, headPos.Y - 25), 
                                target.Name, color)
                            table.insert(espObjects, nameLabel)
                        end
                        
                        if settings.espHealth then
                            local healthText = string.format("%.0f%%", humanoid.Health / humanoid.MaxHealth * 100)
                            local healthLabel = drawText(screenGui, Vector2.new(headPos.X, headPos.Y + 5), 
                                healthText, Color3.fromRGB(255, 0, 0))
                            table.insert(espObjects, healthLabel)
                        end
                        
                        if settings.espDistance then
                            local dist = math.round((camera.CFrame.Position - rootPart.Position).Magnitude)
                            local distLabel = drawText(screenGui, Vector2.new(headPos.X, headPos.Y + 25), 
                                dist .. " m", Color3.fromRGB(255, 255, 255))
                            table.insert(espObjects, distLabel)
                        end
                    end
                end
            end
        end
    end
end)

-- ============================================
-- AIMBOT
-- ============================================
local function getClosestPlayerToMouse()
    local mousePos = userInputService:GetMouseLocation()
    local closestPlayer = nil
    local closestDistance = settings.fovRadius
    
    for _, target in ipairs(getPlayers()) do
        local character = target.Character
        if character and character:FindFirstChild("HumanoidRootPart") and character:FindFirstChild("Head") then
            local head = character.Head
            local headPos, onScreen = worldToScreen(head.Position)
            
            if onScreen then
                local distance = (mousePos - headPos).Magnitude
                if distance < closestDistance then
                    closestDistance = distance
                    closestPlayer = target
                end
            end
        end
    end
    
    return closestPlayer
end

-- Функция для наведения
